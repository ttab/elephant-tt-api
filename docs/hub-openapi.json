                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "ActivatePublishingKey",
        "tags": [
          "Hub"
        ]
      }
    },
