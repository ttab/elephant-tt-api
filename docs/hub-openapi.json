            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ttab.hub.ActivateDeployKeyResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "ActivateDeployKey",
        "tags": [
          "Hub"
        ]
      }
    },
