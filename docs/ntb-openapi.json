              "type": "string"
            },
            "type": "array"
          },
          "links": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Links contains related links.",
            "type": "object"
          },
          "permissions": {
            "$ref": "#/components/schemas/ttab.ntb.Permissions"
          },
          "persons_shown": {
            "description": "PersonsShown are persons in the image.",
