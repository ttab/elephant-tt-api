        "type": "string"
      },
      "ttab.ntb.Origin": {
        "enum": [
          "ORIGIN_UNSPECIFIED",
          "ORIGIN_UPLOAD",
          "ORIGIN_GUEST",
          "ORIGIN_GUESTFTP",
          "ORIGIN_EMAIL",
          "ORIGIN_IMPORT",
          "ORIGIN_FTP",
          "ORIGIN_LTR",
          "ORIGIN_PS",
          "ORIGIN_CMS"
        ],
        "type": "string"
      },
      "ttab.ntb.OriginInfo": {
        "properties": {
          "key": {
            "description": "Key is the key of the origin.",
