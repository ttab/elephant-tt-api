{
  "components": {
    "schemas": {
      "ttab.ntb.File": {
        "properties": {
          "height": {
            "description": "Height is the height of the media in pixels.",
            "type": "integer"
          },
          "mime_type": {
            "description": "MimeType is the mimetype of the media.",
            "type": "string"
          },
          "original_filename": {
            "description": "OriginalFilename is the original name of the file.",
            "type": "string"
          },
          "size": {
            "description": "Size is the size of the file in bytes.",
            "type": "integer"
          },
          "width": {
            "description": "Width is the width of the media in pixels.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "ttab.ntb.FileType": {
        "enum": [
          "FILE_TYPE_UNSPECIFIED",
          "FILE_TYPE_IMAGE",
          "FILE_TYPE_VIDEO",
          "FILE_TYPE_PDF",
          "FILE_TYPE_VECTOR",
          "FILE_TYPE_PHOTOSHOP"
        ],
        "type": "string"
      },
      "ttab.ntb.GetItemRequest": {
        "properties": {
          "archive": {
            "description": "Archive to search in.",
            "type": "string"
          },
          "id": {
            "description": "ID of the item to get.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "ttab.ntb.GetItemResponse": {
        "properties": {
          "item": {
            "$ref": "#/components/schemas/ttab.ntb.MediaItem"
          }
        },
        "type": "object"
      },
      "ttab.ntb.GetSortFieldsRequest": {
        "type": "object"
      },
      "ttab.ntb.GetSortFieldsResponse": {
        "properties": {
          "fields": {
            "items": {
              "$ref": "#/components/schemas/ttab.ntb.SortField"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "ttab.ntb.ImpreciseTimestamp": {
        "properties": {
          "precision": {
            "$ref": "#/components/schemas/ttab.ntb.TimestampPrecision"
          },
          "time": {
            "description": "Time as an RFC3339 timestamp.",
            "type": "string"
          },
          "valid_timezone": {
            "description": "ValidTimezone is set to true if the timestamp has a valid timezone, if false the timestamp will use zulu time as a substitute for the unknown timezone.",
            "type": "boolean"
          }
        },
        "type": "object"
      },
      "ttab.ntb.Internal": {
        "properties": {
          "item_id": {
            "description": "ItemID is a non-unique ID of the media provided under upload.",
            "type": "string"
          },
          "origin": {
            "$ref": "#/components/schemas/ttab.ntb.OriginInfo"
          }
        },
        "type": "object"
      },
      "ttab.ntb.Location": {
        "enum": [
          "LOCATION_UNSPECIFIED",
          "LOCATION_IN_GALLERY",
          "LOCATION_NOT_IN_GALLERY",
          "LOCATION_IN_COLLECTIONS",
          "LOCATION_NOT_IN_COLLECTIONS",
          "LOCATION_ALL_ORGANIZATIONS"
        ],
        "type": "string"
      },
      "ttab.ntb.MediaItem": {
        "properties": {
          "alt_text_accessibility": {
            "description": "AltTextAccessibility is a textual description for accessibility.",
            "type": "string"
          },
          "archive": {
            "description": "Archive (mb/ntb/tt).",
            "type": "string"
          },
          "category": {
            "description": "Category corresponds to IPTC category field.",
            "type": "string"
          },
          "city": {
            "description": "City corresponds to IPTC field.",
            "type": "string"
          },
          "country": {
            "description": "Country corresponds to IPTC field.",
            "type": "string"
          },
          "creator": {
            "description": "Creator contains the name of the photographer or company/org.",
            "type": "string"
          },
          "credit_line": {
            "description": "CreditLine corresponds to IPTC field.",
            "type": "string"
          },
          "date_archived": {
            "description": "DateArchived designates the date and time the content was archived.",
            "type": "string"
          },
          "date_created": {
            "$ref": "#/components/schemas/ttab.ntb.ImpreciseTimestamp"
          },
          "description": {
            "description": "Description is a textual description, including captions, of the media.",
