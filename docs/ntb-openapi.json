        "enum": [
          "TS_PRECISION_UNKNOWN",
          "TS_PRECISION_FULL",
          "TS_PRECISION_MINUTE",
          "TS_PRECISION_HOUR",
          "TS_PRECISION_DAY",
          "TS_PRECISION_MONTH",
          "TS_PRECISION_YEAR",
          "TS_PRECISION_DECADE",
          "TS_PRECISION_CENTURY"
